{
  "version": 2,
  "buildCommand": "node ./build.mjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "bundle": false, "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
